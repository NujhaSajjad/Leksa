# ══ Leksa Backend — Environment Variables ════════════════════════════
# Copy this file to .env and fill in your values.
# ⚠  NEVER commit your real .env file — it is listed in .gitignore.

# ── Required ──────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Cloud (production only) ────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# ── Optional: Disable Firestore for local dev ─────────────────────────
# USE_FIRESTORE=false

# ── CORS: Set your frontend URL in production ─────────────────────────
# FRONTEND_URL=https://your-frontend.com
